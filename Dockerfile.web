# Flask front-end. Launches generator containers on the host daemon via the mounted
# Docker socket, so it only needs the docker SDK (no docker CLI) — see requirements.txt.
FROM python:3.12-slim

WORKDIR /app

COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

COPY app.py generator.py ./
COPY templates/ templates/

EXPOSE 5000

# Background generation runs in a thread pool, so POSTs return immediately; the request
# timeout only needs to cover uploads/downloads. Multiple workers each run their own
# pool + reaper, which is fine because all job state lives on the shared disk volume.
CMD ["gunicorn", "--bind", "0.0.0.0:5000", "--workers", "2", "--timeout", "120", "app:app"]
