# Archipelago generator image: AP 0.6.7 frozen build + common apworlds.
# Runs ArchipelagoGenerate headlessly against a mounted /job dir.

# Stage 1: download the apworlds listed in apworlds.csv into /out (no binaries vendored
# in the repo). Kept separate so Python/fetch tooling never lands in the runtime image.
FROM python:3.12-slim AS apworlds
WORKDIR /fetch
COPY apworlds.csv ./
COPY scripts/fetch_apworlds.py ./
RUN python3 fetch_apworlds.py --manifest apworlds.csv --dest /out

# Stage 2: the runtime image.
FROM debian:bookworm-slim

ARG AP_VERSION=0.6.7
ENV AP_HOME=/opt/archipelago

# ca-certificates + curl to fetch the release; libffi8/libssl3 are runtime shared
# libraries the frozen build links against; python3 + python3-yaml drive the per-job
# apworld selection in the entrypoint (see select_apworlds.py).
RUN apt-get update && apt-get install -y --no-install-recommends \
        ca-certificates \
        curl \
        libffi8 \
        libssl3 \
        python3 \
        python3-yaml \
    && rm -rf /var/lib/apt/lists/*

# Fetch and unpack the official linux-x86_64 tarball (bundles its own Python).
RUN curl -fsSL -o /tmp/ap.tar.gz \
        "https://github.com/ArchipelagoMW/Archipelago/releases/download/${AP_VERSION}/Archipelago_${AP_VERSION}_linux-x86_64.tar.gz" \
    && mkdir -p "${AP_HOME}" \
    && tar -xzf /tmp/ap.tar.gz -C "${AP_HOME}" --strip-components=1 \
    && rm /tmp/ap.tar.gz

# Stage the manifest-fetched apworlds (from stage 1) as a LIBRARY, not in custom_worlds:
# the entrypoint copies only the ones each job's YAMLs reference, so AP doesn't import all
# ~460 worlds on every generation. index.json (game -> file) rides along in /out.
ENV AP_LIBRARY=/opt/apworlds-library
COPY --from=apworlds /out/ ${AP_LIBRARY}/

COPY entrypoint.sh /usr/local/bin/entrypoint.sh
COPY scripts/select_apworlds.py /usr/local/bin/select_apworlds.py
RUN chmod +x /usr/local/bin/entrypoint.sh

# Non-root. The whole install must be writable by the runtime user: Archipelago only
# treats the install as "portable" (and thus scans custom_worlds/ for apworlds) when
# os.access(local_path, W_OK) is true. A read-only install makes it look for apworlds in
# the user's home dir instead, so baked-in custom_worlds would be ignored.
RUN useradd --create-home --uid 1000 archipelago \
    && chown -R archipelago:archipelago "${AP_HOME}"
USER archipelago

ENTRYPOINT ["/usr/local/bin/entrypoint.sh"]
